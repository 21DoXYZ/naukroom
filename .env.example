# === Backend (Railway) ===
PORT=3001
JWT_SECRET=change-this-to-a-long-random-string
ANTHROPIC_API_KEY=sk-ant-...

# Path to SQLite file
# Railway: set to /data/naukroom.db and add a Volume at /data in Railway dashboard
DATABASE_PATH=./data/naukroom.db

# Comma-separated allowed frontend origins (your Vercel domain)
# Example: https://naukroom.vercel.app,https://naukroom.com.ua
CORS_ORIGIN=http://localhost:5173

# === Frontend (Vercel) ===
# Full URL of your Railway backend API
# Set this in Vercel dashboard → Project → Settings → Environment Variables
# Example: https://naukroom-api.up.railway.app/api
VITE_API_URL=http://localhost:3001/api
