# ── Backend (Railway) ──────────────────────────────────────────────────────

PORT=3001

# Generate: openssl rand -base64 32
JWT_SECRET=change-this-to-a-long-random-string

# Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# SQLite database path
# Railway: set to /data/naukroom.db and add a Volume at /data
DATABASE_PATH=./data/naukroom.db

# Frontend origin (comma-separated)
CORS_ORIGIN=http://localhost:5173

# App base URL (used in password reset emails)
APP_URL=https://naukroom.vercel.app

# ── Email notifications (Resend — resend.com) ──────────────────────────────
# Free tier: 3000 emails/month
RESEND_API_KEY=re_...

# Your email — receives new submission notifications
ADMIN_EMAIL=your@email.com

# ── Telegram notifications ──────────────────────────────────────────────────
# 1. Open @BotFather → /newbot → copy token
# 2. Message your bot → open https://api.telegram.org/bot<TOKEN>/getUpdates → copy "id"
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Frontend (Vercel) ───────────────────────────────────────────────────────
# Set in Vercel dashboard → Project → Settings → Environment Variables
# After Railway deploy: copy your Railway URL here
VITE_API_URL=http://localhost:3001/api

# ── Instagram profile fetching (Apify) ─────────────────────────────────────
# 1. Register at https://apify.com (free tier: $5 credit/month ≈ 500–1000 profiles)
# 2. Go to Settings → Integrations → API tokens → Create token
# 3. The actor used: apify/instagram-profile-scraper (pre-installed, no extra setup)
APIFY_TOKEN=

# ── Vercel serverless functions ─────────────────────────────────────────────
# Same keys, set via: vercel env add ANTHROPIC_API_KEY production
# vercel env add TELEGRAM_BOT_TOKEN production
# vercel env add TELEGRAM_CHAT_ID production
# vercel env add RAPIDAPI_KEY production
